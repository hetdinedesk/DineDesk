generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         String   @default("EDITOR")
  clientAccess Json     @default("{}")
  createdAt    DateTime @default(now())
}

model GlobalConfig {
  id        String   @id @default("global")
  settings  Json?
  updatedAt DateTime @updatedAt
}

model Group {
  id      String   @id @default(cuid())
  name    String
  color   String   @default("#6366F1")
  clients Client[]
}

model Client {
  id               String            @id
  name             String
  domain           String?
  status           String            @default("draft")
  groupId          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clonable         Boolean           @default(false)
  alerts           AlertPopup[]
  banners          Banner[]
  bookings         Booking[]
  group            Group?            @relation(fields: [groupId], references: [id])
  customTextBlocks CustomTextBlock[]
  customers        Customer[]
  deployments      Deployment[]
  featuredConfig   FeaturedConfig?
  footerLinks      FooterLink[]
  footerSections   FooterSection[]
  formSubmissions  FormSubmission[]
  homeSections     HomeSection[]
  homepageLayout   HomepageLayout?
  legalDocs        LegalDoc[]
  locations        Location[]
  loyaltyConfig    LoyaltyConfig?
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  navigationItems  NavigationItem[]
  orders           Order[]
  pages            Page[]
  paymentGateway   PaymentGateway?
  promoConfig      PromoConfig?
  promoTiles       PromoTile[]
  rewards          Reward[]
  siteConfig       SiteConfig?
  specials         Special[]
  specialsConfig   SpecialsConfig?
  teamDepartments  TeamDepartment[]
  welcomeContent   WelcomeContent?
}

model SiteConfig {
  id            String   @id @default(cuid())
  clientId      String   @unique
  version       Int      @default(1)
  settings      Json?
  netlify       Json?
  colours       Json?
  analytics     Json?
  shortcodes    Json?
  homepage      Json?
  reviews       Json?
  booking       Json?
  notes         Json?
  header        Json?
  footer        Json?
  headerCtas    Json?
  social        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  ordering      Json?
  posConfig     Json?
  notifications Json?
  client        Client   @relation(fields: [clientId], references: [id])
}

model Location {
  id                String    @id @default(cuid())
  clientId          String
  name              String
  displayName       String?
  address           String
  suburb            String?
  city              String?
  state             String?
  postcode          String?
  country           String?   @default("Australia")
  phone             String?
  bookingPhone      String?
  deliveryPhone     String?
  lat               String?
  lng               String?
  hours             Json?
  exteriorImage     String?
  exteriorImages    Json?     @default("[]")
  formEmail         String?
  showInFooter      Boolean   @default(false)
  alternateStyling  Boolean   @default(false)
  galleryImages     Json?     @default("[]")
  isPrimary         Boolean   @default(false)
  isActive          Boolean   @default(true)
  deliveryZone      Boolean   @default(false)
  menuCategories    String[]  @default([])
  servicesAvailable String[]  @default([])
  bookings          Booking[]
  tables            RestaurantTable[]
  client            Client    @relation(fields: [clientId], references: [id])
  orders            Order[]

  @@index([clientId])
  @@index([isPrimary])
}

model RestaurantTable {
  id          String   @id @default(cuid())
  clientId    String
  locationId  String
  tableNumber String
  capacity    Int      @default(4)
  qrCodeUrl   String?
  isActive    Boolean  @default(true)
  bookingId   String?
  position    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  booking     Booking? @relation(fields: [bookingId], references: [id])
  orders      Order[]

  @@index([clientId])
  @@index([locationId])
  @@unique([locationId, tableNumber])
}

model MenuCategory {
  id        String     @id @default(cuid())
  clientId  String
  name      String
  sortOrder Int        @default(0)
  client    Client     @relation(fields: [clientId], references: [id])
  items     MenuItem[]

  @@index([clientId])
}

model MenuItem {
  id          String        @id @default(cuid())
  clientId    String
  categoryId  String?
  name        String
  description String?
  price       Float?
  imageUrl    String?
  isAvailable Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  sortOrder    Int           @default(0)
  sizes        Json?         @default("[]")
  addons       Json?         @default("[]")
  hasVariants  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  category    MenuCategory? @relation(fields: [categoryId], references: [id])
  client      Client        @relation(fields: [clientId], references: [id])
}

model Special {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  description String?
  price       Float?
  imageUrl    String?
  bannerImage String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  showInNav   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  client      Client    @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Page {
  id              String           @id @default(cuid())
  clientId        String
  slug            String
  title           String
  subtitle        String?
  content         String?
  metaTitle       String?
  metaDesc        String?
  ogImage         String?
  status          String           @default("draft")
  inNavigation    Boolean          @default(false)
  navOrder        Int              @default(0)
  parentId        String?
  pageType        String           @default("custom")
  bannerId        String?
  showEnquiryForm Boolean          @default(false)
  showLocationMap Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now()) @updatedAt
  footerLinks     FooterLink[]
  navigationItems NavigationItem[]
  banner          Banner?          @relation(fields: [bannerId], references: [id])
  client          Client           @relation(fields: [clientId], references: [id])
  parentPage      Page?            @relation("PageChildren", fields: [parentId], references: [id])
  childPages      Page[]           @relation("PageChildren")

  @@unique([clientId, slug])
  @@index([clientId])
  @@index([slug])
  @@index([bannerId])
}

model Banner {
  id         String   @id @default(cuid())
  clientId   String
  title      String?
  text       String?
  imageUrl   String?
  buttonText String?
  buttonUrl  String?
  isActive   Boolean  @default(true)
  assignTo   Json[]   @default([])
  sortOrder  Int      @default(0)
  widthPx    Int?
  heightPx   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  isExternal Boolean  @default(false)
  location   String   @default("home")
  subtitle   String?
  client     Client   @relation(fields: [clientId], references: [id])
  pages      Page[]

  @@index([clientId])
}

model PromoTile {
  id              String   @id @default(cuid())
  clientId        String
  heading         String?
  subheading      String?
  imageUrl        String?
  linkUrl         String?
  linkLabel       String?
  isExternal      Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  extraHeading    String?
  extraSubheading String?
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model PromoConfig {
  id         String   @id @default(cuid())
  clientId   String   @unique
  heading    String?
  subheading String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model SpecialsConfig {
  id             String   @id @default(cuid())
  clientId       String   @unique
  heading        String?
  subheading     String?
  showOnHomepage Boolean  @default(false)
  maxItems       Int      @default(2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model FeaturedConfig {
  id         String   @id @default(cuid())
  clientId   String   @unique
  heading    String?
  subheading String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model HomepageLayout {
  id         String   @id @default(cuid())
  clientId   String   @unique
  components Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model CustomTextBlock {
  id        String   @id @default(cuid())
  clientId  String
  title     String?
  content   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model WelcomeContent {
  id         String   @id @default(cuid())
  clientId   String   @unique
  subtitle   String?
  heading    String?
  text       String?
  imageUrl   String?
  ctaText    String?
  ctaUrl     String?
  isExternal Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model FooterSection {
  id        String       @id @default(cuid())
  clientId  String
  title     String
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  links     FooterLink[]
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model FooterLink {
  id              String         @id @default(cuid())
  footerSectionId String?
  label           String
  pageId          String?
  externalUrl     String?
  sortOrder       Int            @default(0)
  isActive        Boolean        @default(true)
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  footerSection   FooterSection? @relation(fields: [footerSectionId], references: [id], onDelete: Cascade)
  page            Page?          @relation(fields: [pageId], references: [id])

  @@index([clientId])
  @@index([footerSectionId])
}

model NavigationItem {
  id        String           @id @default(cuid())
  clientId  String
  label     String
  url       String
  isActive  Boolean          @default(true)
  sortOrder Int              @default(0)
  parentId  String?
  pageId    String?
  imageUrl  String?
  client    Client           @relation(fields: [clientId], references: [id])
  page      Page?            @relation(fields: [pageId], references: [id])
  parent    NavigationItem?  @relation("NavChildren", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavChildren")

  @@index([clientId])
  @@index([parentId])
}

model TeamDepartment {
  id                String             @id @default(cuid())
  clientId          String
  name              String
  sortOrder         Int                @default(0)
  isActive          Boolean            @default(true)
  homeSections      HomeSection[]
  memberDepartments MemberDepartment[]
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model MemberDepartment {
  id            String         @id @default(cuid())
  homeSectionId String
  departmentId  String
  department    TeamDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  homeSection   HomeSection    @relation(fields: [homeSectionId], references: [id], onDelete: Cascade)

  @@unique([homeSectionId, departmentId])
  @@index([homeSectionId])
  @@index([departmentId])
}

model HomeSection {
  id                String             @id @default(cuid())
  clientId          String
  type              String
  title             String?
  content           String?
  imageUrl          String?
  buttonText        String?
  buttonUrl         String?
  sortOrder         Int                @default(0)
  isActive          Boolean            @default(true)
  departmentId      String?
  client            Client             @relation(fields: [clientId], references: [id])
  department        TeamDepartment?    @relation(fields: [departmentId], references: [id])
  memberDepartments MemberDepartment[]

  @@index([clientId])
  @@index([sortOrder])
  @@index([departmentId])
}

model AlertPopup {
  id            String    @id @default(cuid())
  clientId      String
  title         String
  message       String
  startDate     DateTime?
  endDate       DateTime?
  pages         Json[]    @default([])
  isDismissible Boolean   @default(true)
  isActive      Boolean   @default(true)
  client        Client    @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model PaymentGateway {
  id          String  @id @default(cuid())
  clientId    String  @unique
  provider    String  @default("stripe")
  config      Json
  isActive    Boolean @default(false)
  currency    String  @default("AUD")
  taxRate     Float   @default(0.1)
  cashEnabled Boolean @default(true)
  cashLabel   String  @default("Pay at Pickup")
  testMode    Boolean @default(true)
  orders      Order[]
  client      Client  @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Customer {
  id          String   @id @default(cuid())
  clientId    String
  phone       String
  name        String?
  email       String?
  points      Int      @default(0)
  totalOrders Int      @default(0)
  totalSpent  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([clientId, phone])
  @@index([clientId])
  @@index([phone])
}

model LoyaltyConfig {
  id              String   @id @default(cuid())
  clientId        String   @unique
  enabled         Boolean  @default(false)
  pointsPerDollar Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rewards         Reward[]

  @@index([clientId])
}

model Reward {
  id              String        @id @default(cuid())
  clientId        String
  loyaltyConfigId String
  name            String
  description     String?
  pointsRequired  Int
  discountValue   Float
  discountType    String        @default("fixed")
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  loyaltyConfig   LoyaltyConfig @relation(fields: [loyaltyConfigId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([loyaltyConfigId])
}

model Order {
  id                    String          @id @default(cuid())
  clientId              String
  orderNumber           Int
  status                String          @default("new")
  items                 Json
  subtotal              Float
  taxAmount             Float
  total                 Float
  currency              String          @default("AUD")
  customerName          String
  customerEmail         String
  customerPhone         String
  orderType             String          @default("pickup")
  pickupTime            DateTime?
  paymentMethod         String          @default("cash")
  paymentStatus         String          @default("pending")
  stripePaymentIntentId String?
  note                  String?
  deliveryFee           Float           @default(0)
  paymentGatewayId      String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  acceptedAt            DateTime?
  preparingAt           DateTime?
  readyAt               DateTime?
  completedAt           DateTime?
  customerId            String?
  pointsEarned          Int             @default(0)
  pointsUsed            Int             @default(0)
  rewardUsed            Json?
  locationId            String?
  tableId               String?
  paymentPreference     String   @default("upfront")
  discountAmount        Float           @default(0)
  client                Client          @relation(fields: [clientId], references: [id])
  customer              Customer?       @relation(fields: [customerId], references: [id])
  location              Location?       @relation(fields: [locationId], references: [id])
  table                 RestaurantTable? @relation(fields: [tableId], references: [id])
  paymentGateway        PaymentGateway? @relation(fields: [paymentGatewayId], references: [id])

  @@index([clientId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentGatewayId])
  @@index([customerId])
  @@index([locationId])
}

model LegalDoc {
  id       String  @id @default(cuid())
  clientId String
  type     String
  title    String
  content  String
  urlSlug  String?
  isActive Boolean @default(true)
  client   Client  @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Deployment {
  id          String   @id @default(cuid())
  clientId    String
  status      String
  triggeredBy String
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  clientId  String
  formType  String
  data      Json
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityName String?
  userId     String?
  userName   String?
  clientId   String?
  clientName String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Booking {
  id                 String    @id @default(cuid())
  clientId           String
  customerName       String
  customerEmail      String?
  customerPhone      String?
  partySize          Int
  bookingDate        DateTime
  bookingTime        String
  status             String    @default("pending")
  notes              String?
  confirmationMethod String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  locationId         String?
  client             Client    @relation(fields: [clientId], references: [id])
  location           Location? @relation(fields: [locationId], references: [id])
  tables             RestaurantTable[]

  @@index([clientId])
  @@index([locationId])
  @@index([bookingDate])
  @@index([status])
}
