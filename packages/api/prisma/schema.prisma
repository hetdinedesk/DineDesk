// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         String   @default("EDITOR")
  clientAccess Json     @default("{}")
  createdAt    DateTime @default(now())
}

model GlobalConfig {
  id        String   @id @default("global")
  settings  Json?
  updatedAt DateTime @updatedAt
}

model Group {
  id      String   @id @default(cuid())
  name    String
  color   String   @default("#6366F1")
  clients Client[]
}

model Client {
  id              String           @id @default(cuid())
  name            String
  domain          String?
  status          String           @default("draft")
  groupId         String?
  group           Group?           @relation(fields: [groupId], references: [id])
  locations       Location[]
  pages           Page[]
  navigationItems NavigationItem[]
  homeSections    HomeSection[]
  alerts          AlertPopup[]
  paymentGateway  PaymentGateway?
  legalDocs       LegalDoc[]
  siteConfig      SiteConfig?
  deployments     Deployment[]
  menuCategories  MenuCategory[]
  menuItems       MenuItem[]
  specials        Special[]
  banners         Banner[]
  footerSections  FooterSection[]
  formSubmissions FormSubmission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SiteConfig {
  id         String   @id @default(cuid())
  clientId   String   @unique
  client     Client   @relation(fields: [clientId], references: [id])
  version    Int      @default(1)
  settings   Json?
  netlify    Json?
  colours    Json?
  analytics  Json?
  shortcodes Json?
  homepage   Json?
  reviews    Json?
  booking    Json?
  notes      Json?
  header     Json?
  footer     Json?
  headerCtas Json?
  social     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model Location {
  id             String  @id @default(cuid())
  clientId       String
  client         Client  @relation(fields: [clientId], references: [id])
  name           String
  displayName    String?
  address        String
  suburb         String?
  city           String?
  state          String?
  postcode       String?
  country        String? @default("Australia")
  phone          String?
  bookingPhone   String?
  deliveryPhone  String?
  lat            String?
  lng            String?
  hours          Json?
  exteriorImage      String?
  formEmail          String?
  showInFooter       Boolean  @default(false)
  alternateStyling   Boolean  @default(false)  
  galleryImages      Json?    @default("[]")

  isPrimary          Boolean  @default(false)

  isActive           Boolean  @default(true)
  deliveryZone       Boolean  @default(false)
  menuCategories     Json[]   @default([])

  // Single primary per client enforced in API routes
  @@index([clientId])
  @@index([isPrimary])
}

model MenuCategory {
  id        String     @id @default(cuid())
  clientId  String
  client    Client     @relation(fields: [clientId], references: [id])
  name      String
  sortOrder Int        @default(0)
  items     MenuItem[]

  @@index([clientId])
}

model MenuItem {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  categoryId  String?
  category    MenuCategory? @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  price       Float?
  imageUrl    String?
  isAvailable Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
}

model Special {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  title       String
  description String?
  price       Float?
  imageUrl    String?
  bannerImage String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  showInNav   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@index([clientId])
}

model Page {
  id              String           @id @default(cuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  slug            String
  title           String
  content         String?
  metaTitle       String?
  metaDesc        String?
  ogImage         String?
  status          String           @default("draft")
  inNavigation    Boolean          @default(false)
  navOrder        Int              @default(0)
  parentId        String?
  parentPage      Page?            @relation("PageChildren", fields: [parentId], references: [id])
  childPages      Page[]           @relation("PageChildren")
  navigationItems NavigationItem[] @relation
  bannerId        String?
  banner          Banner?          @relation(fields: [bannerId], references: [id], onDelete: SetNull)
  footerLinks     FooterLink[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now()) @updatedAt

  @@unique([clientId, slug])
  @@index([clientId])
  @@index([slug])
  @@index([bannerId])
}

model Banner {
  id         String  @id @default(cuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id])
  title      String?
  text       String
  imageUrl   String?
  buttonText String?
  buttonUrl  String?
  isActive   Boolean @default(true)
  assignTo   Json[]  @default([]) // ["hero", "pages:/about", "specials"]
  sortOrder  Int     @default(0)
  widthPx    Int?
  heightPx   Int?
  pages      Page[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([clientId])
}

model FooterSection {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int          @default(0)
  links     FooterLink[]

  @@index([clientId])
}

model FooterLink {
  id              String        @id @default(cuid())
  footerSectionId String
  footerSection   FooterSection @relation(fields: [footerSectionId], references: [id], onDelete: Cascade)
  label           String
  pageId          String?
  page            Page?         @relation(fields: [pageId], references: [id], onDelete: SetNull)
  externalUrl     String?
  sortOrder       Int           @default(0)

  @@index([footerSectionId])
}

model NavigationItem {
  id        String           @id @default(cuid())
  clientId  String
  client    Client           @relation(fields: [clientId], references: [id])
  label     String
  url       String
  isActive  Boolean          @default(true)
  sortOrder Int              @default(0)
  parentId  String?
  parent    NavigationItem?  @relation("NavChildren", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavChildren")
  pageId    String?
  page      Page?            @relation(fields: [pageId], references: [id])

  @@index([clientId])
  @@index([parentId])
}

model HomeSection {
  id         String  @id @default(cuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id])
  type       String // "hero", "featured-menu", "specials", "cta", "reviews"
  title      String?
  content    String?
  imageUrl   String?
  buttonText String?
  buttonUrl  String?
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  @@index([clientId])
  @@index([sortOrder])
}

model AlertPopup {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  title         String
  message       String
  startDate     DateTime?
  endDate       DateTime?
  pages         Json[]    @default([]) // ["/", "/menu"]
  isDismissible Boolean   @default(true)
  isActive      Boolean   @default(true)

  @@index([clientId])
}

model PaymentGateway {
  id       String  @id @default(cuid())
  clientId String  @unique
  client   Client  @relation(fields: [clientId], references: [id])
  provider String // "stripe", "paypal"
  config   Json // API keys, etc.
  isActive Boolean @default(false)
  currency String  @default("AUD")
  taxRate  Float   @default(0.1)

  @@index([clientId])
}

model LegalDoc {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id])
  type     String // "privacy", "terms", "cookies"
  title    String
  content  String
  urlSlug  String?
  isActive Boolean @default(true)

  @@index([clientId])
}

model Deployment {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  status      String
  triggeredBy String
  createdAt   DateTime @default(now())

  @@index([clientId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  formType  String
  data      Json
  createdAt DateTime @default(now())

  @@index([clientId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityName String?
  userId     String?
  userName   String?
  clientId   String?
  clientName String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
