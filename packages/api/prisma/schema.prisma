// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         String   @default("EDITOR")
  clientAccess Json     @default("{}")
  createdAt    DateTime @default(now())
}

model GlobalConfig {
  id        String   @id @default("global")
  settings  Json?
  updatedAt DateTime @updatedAt
}

model Group {
  id      String   @id @default(cuid())
  name    String
  color   String   @default("#6366F1")
  clients Client[]
}

model Client {
  id              String           @id
  name            String
  domain          String?
  status          String           @default("draft")
  groupId         String?
  group           Group?           @relation(fields: [groupId], references: [id])
  clonable        Boolean          @default(false)
  locations       Location[]
  pages           Page[]
  navigationItems NavigationItem[]
  homeSections    HomeSection[]
  alerts          AlertPopup[]
  paymentGateway  PaymentGateway?
  orders          Order[]
  legalDocs       LegalDoc[]
  siteConfig      SiteConfig?
  deployments     Deployment[]
  menuCategories  MenuCategory[]
  menuItems       MenuItem[]
  specials        Special[]
  banners         Banner[]
  footerSections  FooterSection[]
  footerLinks     FooterLink[]
  formSubmissions FormSubmission[]
  promoTiles      PromoTile[]
  promoConfig     PromoConfig?
  specialsConfig  SpecialsConfig?
  featuredConfig  FeaturedConfig?
  welcomeContent  WelcomeContent?
  teamDepartments TeamDepartment[]
  homepageLayout  HomepageLayout?
  customTextBlocks CustomTextBlock[]
  customers       Customer[]
  loyaltyConfig   LoyaltyConfig?
  rewards         Reward[]
  bookings        Booking[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SiteConfig {
  id         String   @id @default(cuid())
  clientId   String   @unique
  client     Client   @relation(fields: [clientId], references: [id])
  version    Int      @default(1)
  settings   Json?
  netlify    Json?
  colours    Json?
  analytics  Json?
  shortcodes Json?
  homepage   Json?
  posConfig  Json?
  reviews    Json?
  booking    Json?
  notes      Json?
  header     Json?
  footer     Json?
  headerCtas Json?
  social     Json?
  ordering   Json?
  notifications Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model Location {
  id             String  @id @default(cuid())
  clientId       String
  client         Client  @relation(fields: [clientId], references: [id])
  name           String
  displayName    String?
  address        String
  suburb         String?
  city           String?
  state          String?
  postcode       String?
  country        String? @default("Australia")
  phone          String?
  bookingPhone   String?
  deliveryPhone  String?
  lat            String?
  lng            String?
  hours          Json?
  exteriorImage      String?     // @deprecated - use exteriorImages instead
  exteriorImages     Json?       @default("[]")  // Array of exterior image URLs
  formEmail          String?
  showInFooter       Boolean  @default(false)
  alternateStyling   Boolean  @default(false)
  galleryImages      Json?    @default("[]")

  isPrimary          Boolean  @default(false)

  isActive           Boolean  @default(true)
  deliveryZone       Boolean  @default(false)
  menuCategories     String[] @default([])
  servicesAvailable  String[] @default([])
  orders             Order[]
  bookings           Booking[]

  // Single primary per client enforced in API routes
  @@index([clientId])
  @@index([isPrimary])
}

model MenuCategory {
  id        String     @id @default(cuid())
  clientId  String
  client    Client     @relation(fields: [clientId], references: [id])
  name      String
  sortOrder Int        @default(0)
  items     MenuItem[]

  @@index([clientId])
}

model MenuItem {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  categoryId  String?
  category    MenuCategory? @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  price       Float?
  imageUrl    String?
  isAvailable Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
}

model Special {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  title       String
  description String?
  price       Float?
  imageUrl    String?
  bannerImage String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  showInNav   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@index([clientId])
}

model Page {
  id              String           @id @default(cuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  slug            String
  title           String
  subtitle        String?
  content         String?
  metaTitle       String?
  metaDesc        String?
  ogImage         String?
  status          String           @default("draft")
  inNavigation    Boolean          @default(false)
  navOrder        Int              @default(0)
  parentId        String?
  parentPage      Page?            @relation("PageChildren", fields: [parentId], references: [id])
  childPages      Page[]           @relation("PageChildren")
  navigationItems NavigationItem[] @relation
  pageType        String           @default("custom")
  bannerId        String?
  banner          Banner?          @relation(fields: [bannerId], references: [id], onDelete: SetNull)
  showEnquiryForm Boolean          @default(false)
  showLocationMap Boolean          @default(false)
  footerLinks     FooterLink[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now()) @updatedAt

  @@unique([clientId, slug])
  @@index([clientId])
  @@index([slug])
  @@index([bannerId])
}

model Banner {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id])
  title       String?
  subtitle    String? // Subheading for banner
  text        String?
  imageUrl    String?
  buttonText  String?
  buttonUrl   String? // Can be internal (/about) or external (https://...)
  isExternal  Boolean @default(false) // Flag to indicate external link
  isActive    Boolean @default(true)
  location    String  @default("home") // "home", "pages", "both"
  assignTo    Json[]  @default([]) // Legacy: ["hero", "pages:/about"]
  sortOrder   Int     @default(0)
  widthPx     Int?
  heightPx    Int?
  pages       Page[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([clientId])
}

model PromoTile {
  id              String  @id @default(cuid())
  clientId        String
  client          Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  heading         String?
  subheading      String?
  extraHeading    String?
  extraSubheading String?
  imageUrl        String?
  linkUrl         String?
  linkLabel       String?
  isExternal      Boolean @default(false)
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([clientId])
}

model PromoConfig {
  id          String  @id @default(cuid())
  clientId    String  @unique
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  heading     String?
  subheading  String?
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model SpecialsConfig {
  id              String  @id @default(cuid())
  clientId        String  @unique
  client          Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  heading         String?
  subheading      String?
  showOnHomepage  Boolean @default(false)
  maxItems        Int     @default(2)
  isActive        Boolean @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model FeaturedConfig {
  id          String  @id @default(cuid())
  clientId    String  @unique
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  heading     String?
  subheading  String?
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model HomepageLayout {
  id          String  @id @default(cuid())
  clientId    String  @unique
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  components  Json    @default("[]") // Array of component objects: { id, type, visible, order }
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model CustomTextBlock {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String?
  content     String?
  isActive    Boolean @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model WelcomeContent {
  id          String  @id @default(cuid())
  clientId    String  @unique
  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subtitle    String? // Small tag like "Est. 2010"
  heading     String? // Main heading like "Welcome to Savoria"
  text        String? // Main text content
  imageUrl    String?
  ctaText     String? // Button text like "Learn Our Story"
  ctaUrl      String? // Button link
  isExternal  Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model FooterSection {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  links     FooterLink[]

  @@index([clientId])
}

model FooterLink {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  footerSectionId String?
  footerSection   FooterSection? @relation(fields: [footerSectionId], references: [id], onDelete: Cascade)
  label           String
  pageId          String?
  page            Page?         @relation(fields: [pageId], references: [id], onDelete: SetNull)
  externalUrl     String?
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)

  @@index([clientId])
  @@index([footerSectionId])
}

model NavigationItem {
  id        String           @id @default(cuid())
  clientId  String
  client    Client           @relation(fields: [clientId], references: [id])
  label     String
  url       String
  imageUrl  String?
  isActive  Boolean          @default(true)
  sortOrder Int              @default(0)
  parentId  String?
  parent    NavigationItem?  @relation("NavChildren", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavChildren")
  pageId    String?
  page      Page?            @relation(fields: [pageId], references: [id])

  @@index([clientId])
  @@index([parentId])
}

model TeamDepartment {
  id            String       @id @default(cuid())
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String
  sortOrder     Int          @default(0)
  isActive      Boolean      @default(true)
  homeSections  HomeSection[]
  memberDepartments MemberDepartment[]

  @@index([clientId])
}

model MemberDepartment {
  id              String        @id @default(cuid())
  homeSectionId   String
  homeSection     HomeSection   @relation(fields: [homeSectionId], references: [id], onDelete: Cascade)
  departmentId    String
  department      TeamDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([homeSectionId, departmentId])
  @@index([homeSectionId])
  @@index([departmentId])
}

model HomeSection {
  id            String           @id @default(cuid())
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id])
  type          String           // "hero", "featured-menu", "specials", "cta", "reviews", "about"
  title         String?
  content       String?
  imageUrl      String?
  buttonText    String?
  buttonUrl     String?
  sortOrder     Int              @default(0)
  isActive      Boolean          @default(true)
  departmentId  String?          // @deprecated - use memberDepartments for multiple departments
  department    TeamDepartment?  @relation(fields: [departmentId], references: [id])
  memberDepartments MemberDepartment[]

  @@index([clientId])
  @@index([sortOrder])
  @@index([departmentId])
}

model AlertPopup {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  title         String
  message       String
  startDate     DateTime?
  endDate       DateTime?
  pages         Json[]    @default([]) // ["/", "/menu"]
  isDismissible Boolean   @default(true)
  isActive      Boolean   @default(true)

  @@index([clientId])
}

model PaymentGateway {
  id           String  @id @default(cuid())
  clientId     String  @unique
  client       Client  @relation(fields: [clientId], references: [id])
  provider     String  @default("stripe") // "stripe", "paypal"
  config       Json // API keys, etc.
  isActive     Boolean @default(false)
  currency     String  @default("AUD")
  taxRate      Float   @default(0.1)
  cashEnabled  Boolean @default(true)
  cashLabel    String  @default("Pay at Pickup")
  testMode     Boolean @default(true)
  orders       Order[]

  @@index([clientId])
}

model Customer {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phone         String
  name          String?
  email         String?
  points        Int      @default(0)
  totalOrders   Int      @default(0)
  totalSpent    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@unique([clientId, phone])
  @@index([clientId])
  @@index([phone])
}

model LoyaltyConfig {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enabled         Boolean  @default(false)
  pointsPerDollar Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  rewards         Reward[]

  @@index([clientId])
}

model Reward {
  id              String       @id @default(cuid())
  clientId        String
  client          Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  loyaltyConfig   LoyaltyConfig @relation(fields: [loyaltyConfigId], references: [id], onDelete: Cascade)
  loyaltyConfigId String
  name            String
  description     String?
  pointsRequired  Int
  discountValue   Float
  discountType    String       @default("fixed") // "fixed" or "percentage"
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([clientId])
  @@index([loyaltyConfigId])
}

model Order {
  id                    String         @id @default(cuid())
  clientId              String
  client                Client         @relation(fields: [clientId], references: [id])
  customerId            String?
  customer              Customer?      @relation(fields: [customerId], references: [id])
  orderNumber           Int
  status                String         @default("new") // "new", "preparing", "ready", "completed", "cancelled"
  items                 Json // Snapshot of cart items with quantities, prices, options
  subtotal              Float
  taxAmount             Float
  total                 Float
  currency              String         @default("AUD")
  customerName          String
  customerEmail         String
  customerPhone         String
  orderType             String         @default("pickup") // "pickup", "delivery", "dine-in"
  pickupTime            DateTime?
  paymentMethod         String         @default("cash") // "stripe", "cash"
  paymentStatus         String         @default("pending") // "pending", "paid", "failed"
  stripePaymentIntentId String?
  note                  String?
  deliveryFee           Float          @default(0)
  paymentGatewayId      String?
  paymentGateway        PaymentGateway? @relation(fields: [paymentGatewayId], references: [id])
  locationId            String?
  location              Location?      @relation(fields: [locationId], references: [id])
  pointsEarned          Int            @default(0)
  pointsUsed            Int            @default(0)
  rewardUsed            Json?
  discountAmount        Float          @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([clientId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentGatewayId])
  @@index([customerId])
  @@index([locationId])
}

model LegalDoc {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id])
  type     String // "privacy", "terms", "restaurant-terms", "cookies"
  title    String
  content  String
  urlSlug  String?
  isActive Boolean @default(true)

  @@index([clientId])
}

model Deployment {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  status      String
  triggeredBy String
  createdAt   DateTime @default(now())

  @@index([clientId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  formType  String
  data      Json
  createdAt DateTime @default(now())

  @@index([clientId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityName String?
  userId     String?
  userName   String?
  clientId   String?
  clientName String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Booking {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  customerName    String
  customerEmail   String?
  customerPhone   String?
  partySize       Int
  bookingDate     DateTime
  bookingTime     String
  status          String   @default("pending") // "pending", "confirmed", "cancelled"
  notes           String?
  confirmationMethod String // "email", "phone"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
  @@index([locationId])
  @@index([bookingDate])
  @@index([status])
}
