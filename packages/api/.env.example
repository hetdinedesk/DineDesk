# ── Database ───────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── Authentication ─────────────────────────────
# Generate a strong 32+ character secret
JWT_SECRET="your-secure-jwt-secret-min-32-chars-long"

# ── Netlify Deployment (REQUIRED for site creation) ─
NETLIFY_TOKEN="your-netlify-personal-access-token"
SITE_TEMPLATE_REPO=yourusername/DineDesk
SITE_TEMPLATE_REPO_BRANCH=main
SITE_TEMPLATE_BASE_DIR=packages/site-template

# ── API URLs ───────────────────────────────────
NEXT_PUBLIC_CMS_API_URL=https://your-api-domain.com/api
CMS_API_URL=https://your-api-domain.com/api
PUBLIC_API_URL=https://your-api-domain.com

# ── Cloudflare R2 (Optional - for image storage) ─
# Leave empty to use local filesystem storage
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# ── Google Analytics 4 (REQUIRED for Dashboard Analytics) ─
GA4_SERVICE_ACCOUNT=

# ── Google Places API (Optional - for live Google reviews) ─
GOOGLE_PLACES_API_KEY=

# ── Geocoding API (Optional - for location coordinates) ─
GEOCODING_API_KEY=

# ── CORS (REQUIRED for production) ─
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-cms-domain.com,https://your-site-domain.com

# ── Stripe (REQUIRED for payments) ─────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Stripe Connect (REQUIRED for per-restaurant Stripe onboarding) ─
# Get these from Stripe Dashboard → Connect → Settings
STRIPE_CLIENT_ID=ca_your_stripe_connect_client_id

# ── CMS Origin (REQUIRED for Stripe Connect return URLs) ─
# The URL where your CMS is hosted (used as the return_url after Stripe onboarding)
CMS_ORIGIN=https://your-cms-domain.com

# ── SendGrid (Optional - for email notifications) ─
SENDGRID_API_KEY=SG.your_sendgrid_key

# ── Server Configuration ───────────────────────
PORT=3001
NODE_ENV=production

# ── POS Integration ────────────────────────────
# 64-char hex key (run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
POS_ENCRYPTION_KEY=

# Square POS (OAuth)
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_REDIRECT_URI=https://your-cms-domain.com/pos/oauth/square/callback

# Clover POS (OAuth)
CLOVER_APP_ID=
CLOVER_APP_SECRET=

# ── PRODUCTION CHECKLIST ───────────────────────
# 1. Change NODE_ENV to "production"
# 2. Set DATABASE_URL to your production database
# 3. Set CORS_ORIGINS to your actual production domains
# 4. Set STRIPE_WEBHOOK_SECRET from Stripe Dashboard
# 5. Ensure API is served over HTTPS
# 6. Set up automated daily database backups
